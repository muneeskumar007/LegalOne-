# LegalOne Backend Configuration
# Copy this to .env and edit as needed

# ── Ollama Settings ───────────────────────────────────────────────
# URL where Ollama is running
OLLAMA_BASE_URL=http://localhost:11434

# Model to use — options: llama3, phi3, mistral, gemma2, llama3:8b
OLLAMA_MODEL=llama3

# Timeout in seconds for LLM calls (CPU is slow — keep at 120+)
OLLAMA_TIMEOUT=120

# ── RAG Settings ──────────────────────────────────────────────────
# Number of legal provisions to retrieve per query
RAG_TOP_K=5

# Embedding model (free, ~80 MB, auto-downloaded on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── API Settings ──────────────────────────────────────────────────
# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# ── Feature Flags ─────────────────────────────────────────────────
# Set to "template" to always use template (skip Ollama, instant)
# Set to "ollama" to always try Ollama first
DRAFT_ENGINE=ollama
